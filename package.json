{
  "name": "parlhubcom",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "scripts": {
    "build": "react-router build",
    "postbuild": "node deploy/precompress.mjs",
    "dev": "react-router dev",
    "start": "PORT=5555 node --enable-source-maps --env-file-if-exists=.env ./server.cjs",
    "typecheck": "react-router typegen && tsc",
    "verify:metas": "tsx .agents/verify-loc-metas.ts",
    "verify:safehref": "tsx .agents/verify-safe-href.ts",
    "test:a11y": "pa11y-ci",
    "import": "tsx ingest/run.ts",
    "import:remote": "tsx ingest/run-remote.ts",
    "deploy:binfmt": "docker run --privileged --rm tonistiigi/binfmt --install arm64",
    "deploy": "sst deploy --stage production"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@duckdb/node-api": "^1.5.4-r.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@mcp-b/global": "^4.0.0",
    "@mcp-b/react-webmcp": "^4.0.0",
    "@react-router/express": "8.0.0",
    "@react-router/node": "8.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "compression": "^1.8.1",
    "csp-header": "^6.3.1",
    "dot-prop": "^10.1.0",
    "express": "^5.2.1",
    "express-static-gzip": "^3.0.1",
    "isbot": "^5.1.36",
    "lucide-react": "^1.21.0",
    "morgan": "^1.10.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "8.0.0",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "typia": "^11.0.3",
    "xss": "^1.0.15",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.1088.0",
    "@aws-sdk/client-ecs": "^3.1085.0",
    "@aws-sdk/client-s3": "^3.1085.0",
    "@react-router/dev": "8.0.0",
    "@ryoppippi/unplugin-typia": "^2.6.5",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "pa11y-ci": "^4.1.1",
    "shadcn": "^4.11.0",
    "sst": "^4.17.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vite-plugin-devtools-json": "^1.0.0"
  },
  "overrides": {
    "vite-plugin-devtools-json": {
      "vite": "$vite"
    }
  }
}
